{
  "name": "@yikart/source",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "scripts": {
    "prepare": "command -v git >/dev/null 2>&1 && npx simple-git-hooks || echo 'Git not available, skipping git hooks setup'",
    "lint": "nx run-many --target=lint --nxBail --outputStyle=static --parallel=\"75%\"",
    "ai:serve": "nx serve aitoearn-ai",
    "server:serve": "nx serve aitoearn-server"
  },
  "dependencies": {
    "@xdevplatform/xdk": "0.5.0",
    "apify-client": "2.23.0",
    "commander": "14.0.3",
    "reflect-metadata": "0.2.2",
    "tslib": "2.8.1",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "8.2.0",
    "@eslint/js": "9.39.4",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.19",
    "@nx/eslint": "22.7.1",
    "@nx/eslint-plugin": "22.7.1",
    "@nx/js": "22.7.1",
    "@nx/nest": "22.7.1",
    "@nx/node": "22.7.1",
    "@nx/vite": "22.7.1",
    "@nx/vitest": "22.7.1",
    "@nx/workspace": "22.7.1",
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "9.39.4",
    "eslint-plugin-format": "2.0.1",
    "eslint-plugin-import": "2.32.0",
    "git-commit-msg-linter": "5.0.8",
    "jsonc-eslint-parser": "3.1.0",
    "lint-staged": "16.4.0",
    "nx": "22.7.1",
    "simple-git-hooks": "2.13.1",
    "typescript": "5.9.3",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "zx": "8.8.5"
  },
  "simple-git-hooks": {
    "pre-commit": "NX_DAEMON=false pnpm lint-staged",
    "preserveUnused": true
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "nx affected -t lint --files --nxBail --outputStyle=static"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "5.3.4"
    }
  },
  "nx": {
    "includedScripts": []
  }
}
