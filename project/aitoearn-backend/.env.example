# ===================
# 数据库配置
# ===================
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_USERNAME=
MONGODB_PASSWORD=
# 注意: MONGODB_USERNAME 和 MONGODB_PASSWORD 需要你本地 MongoDB 实例的实际账号密码

# ===================
# Redis 配置
# ===================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# 注意: 如果本地 Redis 没有设置密码，留空即可

# ===================
# 应用基础配置
# ===================
NODE_ENV=development
APP_DOMAIN=localhost:3002

# ===================
# 认证配置 ⚠️ 重要
# ===================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
INTERNAL_TOKEN=your-internal-service-token-change-in-production
# 注意: JWT_SECRET 是签发用户 Token 的密钥，必须是复杂的随机字符串
# 注意: INTERNAL_TOKEN 是内部服务通信的凭证，必须妥善保管

# ===================
# 第三方 OAuth 配置
# 说明: 以下平台应用需要向各平台申请开发者账号并创建应用后获取
# ===================

# Bilibili
BILIBILI_CLIENT_ID=
BILIBILI_CLIENT_SECRET=
# 不能填写原因: 需要在 Bilibili 开放平台 (open.bilibili.com) 创建应用后获取

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 不能填写原因: 需要在 Google Cloud Console 创建 OAuth 客户端 ID

# Twitter / X
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# 不能填写原因: 需要在 Twitter Developer Portal 创建应用后获取

# Facebook / Meta
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CONFIG_ID=
# 不能填写原因: 需要在 Meta Developers 创建应用后获取

# Instagram (与 Facebook 共用 Meta 应用)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
# 不能填写原因: 与 Facebook 相同，在 Meta Developers 创建应用

# Threads (与 Facebook 共用 Meta 应用)
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
# 不能填写原因: 与 Facebook 相同，在 Meta Developers 创建应用

# Pinterest
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_TEST_AUTHORIZATION=
# 不能填写原因: 需要在 Pinterest Developers 创建应用后获取

# TikTok
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
# 不能填写原因: 需要在 TikTok Developers 创建应用后获取

# Kwai
KWAI_CLIENT_ID=
KWAI_CLIENT_SECRET=
# 不能填写原因: 需要在快手开放平台申请创建应用

# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# 不能填写原因: 需要在 Google Cloud Console 创建 OAuth 客户端 ID (与 Google 共用)

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# 不能填写原因: 需要在 LinkedIn Developers 创建应用后获取

# 抖音
DOYIN_CLIENT_ID=
DOYIN_CLIENT_SECRET=
# 不能填写原因: 需要在抖音开放平台申请创建应用

# 微信公众号
WXPLAT_APP_ID=
WXPLAT_APP_SECRET=
WXPLAT_ENCODING_AES_KEY=
# 不能填写原因: 需要在微信公众平台申请公众号后获取

# ===================
# 邮件配置 (用于发送邮件)
# 说明: 使用 AWS SES 或其他邮件服务
# ===================
MAIL_USER=
MAIL_PASS=
# 不能填写原因: 需要配置 AWS SES 或其他邮件服务的账号密码

# ===================
# 短信配置 (用于发送验证码)
# 说明: 使用阿里云短信服务
# ===================
ALI_SMS_ACCESS_KEY_ID=
ALI_SMS_ACCESS_KEY_SECRET=
ALI_SMS_SIGN_NAME=
ALI_SMS_TEMPLATE_CODE=
# 不能填写原因: 需要在阿里云控制台开通短信服务并创建签名和模板

# ===================
# AI 服务配置
# ===================
AI_URL=
# 不能填写原因: AI 服务 URL 需要根据你部署的 AI 服务地址配置

# ===================
# 素材存储配置 (JSON 格式)
# ===================
ASSETS_CONFIG={}
# 说明: JSON 格式的配置，指定素材存储方式 (本地/S3/R2 等)

# ===================
# 中转服务配置 (可选)
# ===================
RELAY_SERVER_URL=
RELAY_API_KEY=
RELAY_CALLBACK_URL=
# 注意: 可选配置，用于第三方 API 中转
